# 飞书应用凭证（必填）
LARK_APP_ID=cli_xxxxx
LARK_APP_SECRET=xxxxx

# 飞书 OAuth 回调地址（prod 的 fly.dev 域名）
APP_BASE_URL=

# 飞书事件订阅（配置回调 URL 后飞书自动生成，可选）
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Managed Agent（运行 setup_agent.py 后填写）
AGENT_ID=
AGENT_VERSION=

# Ingest 服务（可选，默认每小时拉一次新妙记）
INGEST_INTERVAL_SECONDS=3600

# ========== v0.2 新增 ==========

# 应用数据库（v0.2 的 customers / records / wiki 索引等）
APP_DB_PATH=db/app.sqlite

# Wiki 目录（跟进记录 ingest 写 customers/<客户>.md）
# 相对路径拼到项目根；Fly 上用 /data/wiki 走持久卷
WIKI_DIR=wiki

# 运行环境：
#   dev  → 跟进记录照片写本地 PHOTO_DIR，便于反复测试后 rm -rf 清理
#   prod → 照片上传飞书 im/v1/images（租户私有存储）
APP_ENV=dev
PHOTO_DIR=data/photos

# ByteHouse CRM 数仓（只读）
BH_HOST=tenant-2102845820-cn-beijing-public.bytehouse.volces.com
BH_PORT=19000
BH_USER=bytehouse
BH_PASSWORD=
BH_WAREHOUSE=vw-2102845820-intco
BH_DATABASE_ODS=ODS_YL
BH_DATABASE_DWD=DWD_YL
